# Copy this file to .env and fill in real values.
# Never commit .env or any file containing real secrets.

# --- LLM ---
# Provider is fixed to "openai" for this PoC (see README > Libraries Used & Why).
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Session management ---
# Minutes an idle session's DuckDB connection is kept before eviction.
SESSION_TTL_MINUTES=30

# --- Upload / query limits ---
MAX_UPLOAD_SIZE_MB=50
MAX_ROWS_RETURNED=5000
QUERY_TIMEOUT_SECONDS=10
# Timeout for calls to the LLM API itself (SQL generation / summary synthesis).
LLM_TIMEOUT_SECONDS=20

# --- Multi-turn chat ---
# How many previous turns are fed into the LLM as context so follow-up
# questions ("now break it down by category") resolve against the right
# prior question/SQL/intent instead of being treated as fresh questions.
HISTORY_TURNS_CONTEXT=3

# --- Rate limiting ---
# Simple in-memory token bucket per session (a production deployment would
# use Redis or similar for a shared, multi-worker-safe limiter).
RATE_LIMIT_CAPACITY=10
RATE_LIMIT_REFILL_PER_MINUTE=20

# --- CORS ---
# Origin the backend allows to call it (the frontend's URL).
FRONTEND_ORIGIN=http://localhost:3000

# --- Frontend ---
# URL the browser uses to reach the backend. Must be set at build time for
# Docker (see frontend/Dockerfile), or in frontend/.env.local for local dev.
NEXT_PUBLIC_API_URL=http://localhost:8000
